{
  "host": "tigrcorn.com",
  "zone": "tigrcorn.com",
  "repository": "tigrbl/tigrcorn-com",
  "siteKind": "mdwrk-lander",
  "orchestrator": "npmctl",
  "dnsProvider": "namecheap",
  "deployment": "self-hosted-docker",
  "dockerService": "tigrcorn-com",
  "records": [
    {
      "type": "A",
      "host": "@",
      "value": "SITE_SERVER_IP_SECRET",
      "ttl": 300
    },
    {
      "type": "A",
      "host": "*.tigrcorn.com",
      "value": "SITE_SERVER_IP_SECRET",
      "ttl": 300
    },
    {
      "type": "CNAME",
      "host": "www",
      "value": "tigrcorn.com",
      "ttl": 300
    }
  ],
  "proxyManager": {
    "provider": "nginx-proxy-manager",
    "apiEndpoint": "NPM_BASE_URL_SECRET"
  }
}
