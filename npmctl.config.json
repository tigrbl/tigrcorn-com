{
  "schemaVersion": 1,
  "site": "tigrcorn.com",
  "repository": "tigrbl/tigrcorn-com",
  "orchestrator": "npmctl",
  "dns": {
    "provider": "namecheap",
    "zone": "tigrcorn.com",
    "records": [
      {
        "type": "A",
        "host": "@",
        "value": "SELF_HOSTED_DOCKER_IP",
        "ttl": 300
      },
      {
        "type": "CNAME",
        "host": "www",
        "value": "tigrcorn.com",
        "ttl": 300
      }
    ]
  },
  "deploy": {
    "target": "self-hosted-docker",
    "service": "tigrcorn-com",
    "composeFile": "docker-compose.yaml"
  },
  "commands": {
    "install": "npm ci",
    "check": "npm run check",
    "build": "npm run build",
    "docker:build": "docker compose build tigrcorn-com",
    "dns:plan": "node scripts/namecheap-dns.mjs --plan",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "deploy": "docker compose up -d --build --force-recreate --no-deps tigrcorn-com"
  }
}
