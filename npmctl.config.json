{
  "schemaVersion": 1,
  "site": "tigrcorn.com",
  "repository": "tigrbl/tigrcorn-com",
  "orchestrator": "npmctl-pypi",
  "dns": {
    "provider": "namecheap",
    "zone": "tigrcorn.com",
    "records": [
      {
        "type": "A",
        "host": "@",
        "value": "SITE_SERVER_IP_SECRET",
        "ttl": 300
      },
      {
        "type": "A",
        "host": "*.tigrcorn.com",
        "value": "SITE_SERVER_IP_SECRET",
        "ttl": 300
      },
      {
        "type": "CNAME",
        "host": "www",
        "value": "tigrcorn.com",
        "ttl": 300
      }
    ],
    "providerPackage": "npmctl-namecheap"
  },
  "deploy": {
    "target": "self-hosted-docker",
    "service": "tigrcorn-com",
    "composeFile": "docker-compose.yaml",
    "proxyManager": {
      "provider": "nginx-proxy-manager",
      "apiEndpoint": "NPM_BASE_URL_SECRET"
    }
  },
  "commands": {
    "install": "npm ci",
    "check": "npm run check",
    "build": "npm run build",
    "docker:build": "docker compose build tigrcorn-com",
    "dns:plan": "npmctl plan desired-state/dns.yaml --owner tigrcorn-com",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "deploy": "docker compose up -d --build --force-recreate --no-deps tigrcorn-com",
    "npmctl:install": "python -m pip install --upgrade \"npmctl>=0.3.10\" \"npmctl-namecheap>=0.3.10\"",
    "npmctl:validate": "npmctl validate desired-state",
    "npmctl:schema": "npmctl schema check",
    "dns:doctor": "npmctl dns doctor --provider namecheap",
    "dns:apply": "npmctl apply desired-state/dns.yaml --owner tigrcorn-com",
    "proxy:validate": "npmctl validate desired-state/proxy.yaml",
    "proxy:plan": "npmctl plan desired-state/proxy.yaml --owner tigrcorn-com",
    "proxy:apply": "npmctl apply desired-state/proxy.yaml --owner tigrcorn-com"
  },
  "npmctl": {
    "package": "npmctl",
    "dnsProviderPackage": "npmctl-namecheap",
    "installCommand": "python -m pip install --upgrade \"npmctl>=0.3.10\" \"npmctl-namecheap>=0.3.10\"",
    "proxyManagerApiEndpoint": "NPM_BASE_URL_SECRET"
  }
}
