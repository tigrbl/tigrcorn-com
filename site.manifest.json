{
  "host": "tigrcorn.com",
  "zone": "tigrcorn.com",
  "repository": "tigrbl/tigrcorn-com",
  "siteKind": "mdwrk-lander",
  "orchestrator": "npmctl",
  "dnsProvider": "namecheap",
  "deployment": "self-hosted-docker",
  "dockerService": "tigrcorn-com",
  "records": [
    {
      "type": "A",
      "host": "@",
      "value": "SELF_HOSTED_DOCKER_IP",
      "ttl": 300
    },
    {
      "type": "CNAME",
      "host": "www",
      "value": "tigrcorn.com",
      "ttl": 300
    }
  ]
}
